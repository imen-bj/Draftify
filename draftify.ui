          <string notr="true">
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #7C3AED,   /* purple */
        stop:1 #3B82F6    /* blue */
    );
    color: white;                /* text color */
    font-weight: bold;
    border: none;                /* no border line */
    border-radius: 18px;         /* rounded corners */
    padding: 8px 18px;           /* space inside */
}

/* Hover */
QPushButton:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #9D5CFF,   /* lighter purple */
        stop:1 #60A5FA    /* lighter blue */
    );
}

/* Pressed */
QPushButton:pressed {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #5B21B6,   /* darker purple */
        stop:1 #1E40AF    /* darker blue */
    );

</string>
