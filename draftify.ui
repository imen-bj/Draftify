         <item>
          <widget class="QToolButton" name="Button_out">
           <property name="styleSheet">
            <string notr="true">/* Default: integrated, red accent text */
QToolButton {
  qproperty-checkable: false;           /* action, not a toggle */
  qproperty-toolButtonStyle: 2;
  qproperty-iconSize: 20px 20px;

  background: transparent;
  color: rgba(255,255,255,0.95);
  border: none;
  border-radius: 14px;
  padding: 10px 14px;
  margin: 6px 0 0 0;
  text-align: left;
  font-size: 15px;
  font-weight: 700;
}

/* Hover: horizontal red-tinted sweep */
QToolButton:hover {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                              stop:0   rgba(255,255,255,0.18),
                              stop:0.25 rgba(255,200,200,0.18),  /* soft red tint */
                              stop:1    rgba(255,255,255,0.00));
  color: #FFFFFF;
}

/* Pressed: stronger red indicator on the left */
QToolButton:pressed {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                              stop:0   rgba(255,180,180,0.30),
                              stop:1   rgba(255,255,255,0.00));
  border-left: 4px solid rgba(255,120,120,0.95);
  padding-left: 10px;
}
</string>
