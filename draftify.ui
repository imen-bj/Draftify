        <widget class="QTableView" name="tableView_EMPL">
         <property name="geometry">
          <rect>
           <x>10</x>
           <y>10</y>
           <width>1221</width>
           <height>231</height>
          </rect>
         </property>
         <property name="styleSheet">
          <string notr="true">/* === Table === */
QTableView {
    /* même fond que le reste de l’UI */
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #C4B5FD,
                                stop:1 #93C5FD);
    border: none;
    border-radius: 0px;                /* pas d'angles arrondis */
    gridline-color: transparent;       /* pas de quadrillage visible */
    selection-background-color: transparent; /* on gère la sélection nous-mêmes */
    selection-color: white;
    outline: 0;
}

/* === En-têtes horizontaux (ID, Name, …) — exactement ce que tu veux === */
QHeaderView::section {
    background-color: rgba(255, 255, 255, 0.4);
    font-weight: bold;
    padding: 6px;
    border: none;
    color: white;
}

/* === En-têtes verticaux (index 1,2,3…) — même fond que la table === */
QHeaderView::section:vertical {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #C4B5FD,
                                stop:1 #93C5FD);
    border: none;
    padding: 4px;
    color: white;
}

/* === Sélection de ligne (dégradé plus foncé, texte blanc) === */
QTableView::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #7C68D8,   /* violet un peu plus foncé */
                                stop:1 #4A90E2);  /* bleu soutenu */
    color: white;
}



/* === Scrollbar (optionnel, harmonisée) === */
QScrollBar:vertical {
    width: 10px;
    background: transparent;
}
QScrollBar::handle:vertical {
    background: #7C68D8;
    border-radius: 5px;
}
QScrollBar::add-line, QScrollBar::sub-line {
    height: 0px;
}
</string>
