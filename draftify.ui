         <property name="styleSheet">
          <string notr="true">/* Link-like clickable text (real underline via font property in Designer) */
QPushButton#linkBtn {
    background: transparent;
    border: none;              /* remove button chrome */
    padding: 4px 8px;
    font-size: 14px;
    font-weight: 900;
    /* Do NOT try text-decoration in QSS — not supported */
    color: #8B1E3F;            /* base color */
}

QPushButton#linkBtn:hover {
    color: #A92A53;            /* hover (lighter burgundy) */
}

QPushButton#linkBtn:pressed {
    color: #5E1429;            /* clicked/active (darker) */
}

QPushButton#linkBtn:disabled {
    color: #B66A7D;            /* muted/disabled */
}
</string>
