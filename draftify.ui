/* Active (checked): clearer left indicator + gentle sweep */
QToolButton:checked {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                              stop:0   rgba(255,255,255,0.28),
                              stop:0.25 rgba(255,255,255,0.16),
                              stop:1    rgba(255,255,255,0.00));
  color: #FFFFFF;
  border-left: 4px solid rgba(255,255,255,0.85);
  padding-left: 10px; /* compensate for left border */
}

/* Pressed feedback: subtle push-in + darker sweep */
QToolButton:pressed {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                              stop:0   rgba(0,0,0,0.25),
                              stop:0.5 rgba(0,0,0,0.18),
                              stop:1   rgba(0,0,0,0.12));
  padding-top: 11px;
  padding-bottom: 9px; /* tiny press feel */
  border-left: 4px solid rgba(255,255,255,0.70); /* keep left marker */
}
</string>
         </property>
         <property name="text">
          <string>Platformes </string>
         </property>
         <property name="icon">
          <iconset theme="QIcon::ThemeIcon::EditSelectAll"/>
         </property>
        </widget>
       </item>
       <item>
        <spacer name="verticalSpaceryas">
         <property name="orientation">
          <enum>Qt::Orientation::Vertical</enum>
         </property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>20</width>
           <height>40</height>
          </size>
         </property>
        </spacer>
       </item>
       <item>
        <widget class="QToolButton" name="LogoutSideBarEmplyas">
         <property name="styleSheet">
          <string notr="true">/* Default: integrated, red accent text */
QToolButton {
  qproperty-checkable: false;           /* action, not a toggle */
  qproperty-toolButtonStyle: 2;
  qproperty-iconSize: 20px 20px;

  background: transparent;
  color: rgba(255,255,255,0.95);
  border: none;
  border-radius: 14px;
  padding: 10px 14px;
  margin: 6px 0 0 0;
  text-align: left;
  font-size: 15px;
  font-weight: 700;
}

/* Hover: horizontal red-tinted sweep */
QToolButton:hover {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                              stop:0   rgba(255,255,255,0.18),
                              stop:0.25 rgba(255,200,200,0.18),  /* soft red tint */
                              stop:1    rgba(255,255,255,0.00));
  color: #FFFFFF;
}

/* Pressed: stronger red indicator on the left */
QToolButton:pressed {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                              stop:0   rgba(255,180,180,0.30),
                              stop:1   rgba(255,255,255,0.00));
  border-left: 4px solid rgba(255,120,120,0.95);
  padding-left: 10px;
}
</string>
         </property>
         <property name="text">
          <string>Log out</string>
         </property>
         <property name="icon">
          <iconset theme="QIcon::ThemeIcon::SystemLogOut"/>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
