         <item>
          <widget class="QToolButton" name="HomeSideBarEmpl">
           <property name="styleSheet">
            <string notr="true">/* Default: fully integrated, no own background */
QToolButton {
  qproperty-checkable: true;
  qproperty-autoExclusive: true;      /* only one active like tabs */
  qproperty-toolButtonStyle: 2;       /* TextBesideIcon */
  qproperty-iconSize: 20px 20px;

  background: transparent;            /* integrate with sidebar gradient */
  color: rgba(255,255,255,0.92);
  border: none;                       /* no box edges */
  border-radius: 14px;                /* slight rounding just for hit area */
  padding: 10px 14px;
  margin: 4px 0;                      /* vertical rhythm */
  text-align: left;
  font-size: 15px;
  font-weight: 600;
}

/* Hover: horizontal sweep highlight */
QToolButton:hover {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                              stop:0   rgba(255,255,255,0.18),
                              stop:0.25 rgba(255,255,255,0.12),
                              stop:0.5  rgba(255,255,255,0.06),
                              stop:1    rgba(255,255,255,0.00));
  color: #FFFFFF;  /* brighten text */
}

/* Active (checked): clearer left indicator + gentle sweep */
QToolButton:checked {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                              stop:0   rgba(255,255,255,0.28),
                              stop:0.25 rgba(255,255,255,0.16),
                              stop:1    rgba(255,255,255,0.00));
  color: #FFFFFF;
  border-left: 4px solid rgba(255,255,255,0.85);
  padding-left: 10px; /* compensate for left border */
}

/* Pressed feedback: subtle push-in + darker sweep */
QToolButton:pressed {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                              stop:0   rgba(0,0,0,0.25),
                              stop:0.5 rgba(0,0,0,0.18),
                              stop:1   rgba(0,0,0,0.12));
  padding-top: 11px;
  padding-bottom: 9px; /* tiny press feel */
  border-left: 4px solid rgba(255,255,255,0.70); /* keep left marker */
}
</string>
           </property>
           <property name="text">
            <string>Home</string>
           </property>
           <property name="icon">
            <iconset theme="QIcon::ThemeIcon::GoHome"/>
           </property>
           <property name="checkable">
            <bool>true</bool>
           </property>
          </widget>
         </item>
