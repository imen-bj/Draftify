}

/* ====== Title ====== */
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    padding: 0 8px;
    color: #7C3AED;                   /* same shade as border */
    font-size: 21px;                  /* slightly larger */
    font-weight: 800;                 /* thicker text */
    letter-spacing: 0.3px;
}
